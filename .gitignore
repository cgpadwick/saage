# cwe run artifacts (flows write outputs in-place)
flows/*/story.md
flows/*/review.md
flows/*/history.txt
flows/*/job_*.count

# diskcache / sqlite caches written at runtime in the CWD (e.g. mlebench,
# pulled in by the kaggle_solver flow, creates <cwd>/cache/cache.db)
cache/
*.db
*.sqlite
*.sqlite3
